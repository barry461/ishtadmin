<script>
$(document).ready(function(){
    // 禁用 Fancybox Hash 导航，防止登录/注册弹层因 hash 变化而一闪关闭
    try {
        if (typeof $.fancybox !== 'undefined' && $.fancybox.defaults) {
            $.fancybox.defaults.Hash = false;
        }
    } catch (e) {}
    // 登录链接以弹层方式打开，禁止跳转
    $(document).on('click', 'a.bind_login, a[data-fancybox][href*="login"]', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var $el = $(this);
        var url = $el.attr('data-login-src') || $el.attr('data-src') || $el.attr('data-href') || $el.attr('href') || '';
        if (url.indexOf('register') >= 0) return;
        var loginUrl = ($el.hasClass('bind_login') || url.indexOf('login') >= 0) ? (url || '/login') : null;
        if (loginUrl && typeof $.fancybox !== 'undefined') {
            $.fancybox.open({
                src: loginUrl,
                type: 'ajax',
                hash: false,
                loop: false,
                beforeShow: function() {
                    $('.fancybox-container').addClass('fancybox-auth');
                },
                afterClose: function() {
                    $('.fancybox-container').removeClass('fancybox-auth');
                }
            });
            return false;
        }
    });

    // 未登录时点击留言框弹出登录层
    $(document).on('click', '.comment-box-require-login', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var $loginBtn = $('.bind_login');
        if ($loginBtn.length) $loginBtn[0].click();
    });
    $(document).on('mousedown focus', '.comment-box-require-login textarea', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var $loginBtn = $('.bind_login');
        if ($loginBtn.length) $loginBtn[0].click();
    });

    // 登录表单提交
    $(document).on('click', '#login_submit', function(e) {
        e.preventDefault();
        var $btn = $(this);
        var $wrap = $btn.closest('.login-modal-wrapper');
        if (!$wrap.length) return; // layui 弹窗无此 class，由 common.js 处理
        var $user = $wrap.find('#login_user');
        var $pass = $wrap.find('#login_pass');
        var $alert = $wrap.find('.modal-body .alert-danger').first();
        var userVal = ($user.val() || '').trim();
        var passVal = ($pass.val() || '').trim();

        function showErr(msg) {
            if ($alert.length) {
                $alert.text(msg).show().delay(3000).fadeOut();
            } else {
                var $newAlert = $('<div class="alert alert-danger w-100" role="alert"></div>').text(msg);
                $wrap.find('.modal-body').prepend($newAlert);
                $newAlert.delay(3000).fadeOut(function(){ $(this).remove(); });
            }
        }

        if (!userVal) { showErr('帐号不能为空，请输入6-18位数字或字母'); $user.focus(); return; }
        if (userVal.length < 6 || userVal.length > 18) { showErr('帐号需6-18位数字或字母'); $user.focus(); return; }
        if (!passVal) { showErr('密码不能为空，请输入6-18位数字或字母'); $pass.focus(); return; }
        if (passVal.length < 6 || passVal.length > 18) { showErr('密码需6-18位数字或字母'); $pass.focus(); return; }

        $btn.prop('disabled', true).text('登入中...');
        $alert.hide().text('');

        var loginApiUrl = (window.__LOGIN_API__ || '/cn/user/login');
        $.ajax({
            type: 'POST',
            url: loginApiUrl,
            data: {
                login_user: userVal,
                login_pass: passVal,
                remember_me: $wrap.find('#remember_me').is(':checked') ? 1 : 0
            },
            dataType: 'json',
            success: function(res) {
                if (res && res.code === 200) {
                    if (res.userinfo) {
                        try { localStorage.setItem('userinfo', JSON.stringify(res.userinfo)); } catch(_) {}
                        try { localStorage.setItem('userinfologin', JSON.stringify(res.userinfo)); } catch(_) {}
                    }
                    if (typeof $.fancybox !== 'undefined') $.fancybox.close();
                    if (typeof layui !== 'undefined' && layui.layer) {
                        layui.layer.msg(res.msg || '登入成功', { icon: 1, time: 2000 }, function() { location.reload(); });
                    } else {
                        alert(res.msg || '登入成功');
                        location.reload();
                    }
                } else {
                    $alert.text(res && res.msg ? res.msg : '登入失败，请检查帐号密码').show();
                    $btn.prop('disabled', false).text('登入');
                }
            },
            error: function(xhr) {
                var msg = '网络错误，请稍后重试';
                if (xhr && xhr.responseJSON && xhr.responseJSON.msg) msg = xhr.responseJSON.msg;
                else if (xhr && xhr.responseText) {
                    try { var j = JSON.parse(xhr.responseText); if (j.msg) msg = j.msg; } catch(_) {}
                }
                $alert.text(msg).show();
                $btn.prop('disabled', false).text('登入');
            }
        });
    });

    // 注册表单提交（事件委托，与参考站一致：帐号、密码、确认密码三栏）
    $(document).on('click', '#register_submit', function(e) {
        e.preventDefault();
        var $btn = $(this);
        var $wrap = $btn.closest('.register-modal-wrapper');
        var $user = $wrap.find('#reg_username');
        var $pass = $wrap.find('#reg_password');
        var $pass2 = $wrap.find('#reg_confirm_password');
        var $alert = $wrap.find('.modal-body .alert-danger').first();
        var userVal = ($user.val() || '').trim();
        var passVal = ($pass.val() || '').trim();
        var pass2Val = ($pass2.val() || '').trim();

        function showErr(msg) {
            if ($alert.length) {
                $alert.text(msg).show().delay(3000).fadeOut();
            } else {
                var $newAlert = $('<div class="alert alert-danger w-100" role="alert"></div>').text(msg);
                $wrap.find('.modal-body').prepend($newAlert);
                $newAlert.delay(3000).fadeOut(function(){ $(this).remove(); });
            }
        }

        if (!userVal) { showErr('帐号不能为空，请输入6-12位数字或字母'); $user.focus(); return; }
        if (userVal.length < 6 || userVal.length > 12) { showErr('帐号需6-12位数字或字母'); $user.focus(); return; }
        if (!passVal) { showErr('密码不能为空，请输入6-12位数字或字母'); $pass.focus(); return; }
        if (passVal.length < 6 || passVal.length > 12) { showErr('密码需6-12位数字或字母'); $pass.focus(); return; }
        if (!pass2Val) { showErr('请确认密码'); $pass2.focus(); return; }
        if (passVal !== pass2Val) { showErr('两次输入密码不一致'); $pass2.focus(); return; }

        $btn.prop('disabled', true).text('注册中...');
        $alert.hide().text('');

        var regApiUrl = (window.__REGISTER_API__ || '/cn/user/signup');
        $.ajax({
            type: 'POST',
            url: regApiUrl,
            data: {
                username: userVal,
                pass: passVal,
                pass2: pass2Val
            },
            dataType: 'json',
            success: function(res) {
                if (res && res.code === 200) {
                    if (res.userinfo) {
                        try { localStorage.setItem('userinfo', JSON.stringify(res.userinfo)); } catch(_) {}
                    }
                    if (typeof $.fancybox !== 'undefined') $.fancybox.close();
                    if (typeof layui !== 'undefined' && layui.layer) {
                        layui.layer.msg(res.msg || '注册成功', { icon: 1, time: 2000 }, function() { location.reload(); });
                    } else {
                        alert(res.msg || '注册成功');
                        location.reload();
                    }
                } else {
                    $alert.text(res && res.msg ? res.msg : '注册失败，请稍后重试').show();
                    $btn.prop('disabled', false).text('注册');
                }
            },
            error: function(xhr) {
                var msg = '网络错误，请稍后重试';
                if (xhr && xhr.responseJSON && xhr.responseJSON.msg) msg = xhr.responseJSON.msg;
                else if (xhr && xhr.responseText) {
                    try { var j = JSON.parse(xhr.responseText); if (j.msg) msg = j.msg; } catch(_) {}
                }
                $alert.text(msg).show();
                $btn.prop('disabled', false).text('注册');
            }
        });
    });

    $('#search_keyword').keydown(function(e){
        if (e.keyCode === 13) {
            var _this = $(this);
            var keyword_val = $.trim(_this.val());
            if (!keyword_val) {
                _this.focus();
                return false;
            }
            window.location.href = "/search/"+ encodeURIComponent(keyword_val);
            return true;
        }
    });

    $('#on-search').click(function(e){
        var _this = $('#search_keyword');
        var keyword_val = $.trim(_this.val());
        if (!keyword_val) {
            _this.focus();
            return false;
        }
        window.location.href="/search/"+keyword_val;
        _this.val("");
        return true;
    });
});
</script>
